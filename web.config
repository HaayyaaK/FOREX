<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS configuration for the Live Market Dashboard.

  PREREQUISITES (install before this file will fully work):
    1. URL Rewrite 2.1        https://www.iis.net/downloads/microsoft/url-rewrite
    2. Application Request Routing (ARR) 3.0
                              https://www.iis.net/downloads/microsoft/application-request-routing
       After installing ARR, enable the proxy:
         IIS Manager -> server node -> Application Request Routing Cache
           -> Server Proxy Settings -> tick "Enable proxy" -> Apply
       (or run:  appcmd set config -section:system.webServer/proxy /enabled:"True" /commit:apphost)

  WITHOUT ARR: the dashboard still works, but the /api reverse-proxy rule is
  inert. In that case leave the browser talking to the proxy directly on
  port 3001 and add that origin to ALLOWED_ORIGINS in the proxy's .env.

  The Node proxy is NOT hosted by IIS. Run it separately (pm2 or a Windows
  service) on 127.0.0.1:3001; this config only forwards to it.
-->
<configuration>
  <system.webServer>

    <!-- =====================================================================
         MIME types. IIS does not serve .json or .mjs by default, and an
         incorrect type for engine/*.js silently breaks the analysis engine.
         ===================================================================== -->
    <staticContent>
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="application/javascript" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".md" />
      <mimeMap fileExtension=".md" mimeType="text/markdown" />
    </staticContent>

    <!-- =====================================================================
         Compression. The engine is ~250 KB of plain JS; gzip matters.
         ===================================================================== -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    <httpCompression>
      <staticTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
      <dynamicTypes>
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </dynamicTypes>
    </httpCompression>

    <!-- =====================================================================
         Default document
         ===================================================================== -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="dashboard.html" />
      </files>
    </defaultDocument>

    <!-- =====================================================================
         Rewrite rules
         ===================================================================== -->
    <rewrite>
      <rules>
        <!-- Never serve secrets, sources or test fixtures over HTTP. -->
        <rule name="Block sensitive paths" stopProcessing="true">
          <match url="^(\.env|\.git|node_modules|tests|backtest)(/.*)?$" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found"
                  statusDescription="Not Found" />
        </rule>

        <!-- Reverse-proxy the API to the Node gateway (requires ARR proxy enabled).
             NOTE: no <serverVariables> here. Setting HTTP_X_FORWARDED_* requires
             those names to be registered in the apphost-level
             system.webServer/rewrite/allowedServerVariables list; if they are not,
             URL Rewrite fails the whole rule with "500 URL Rewrite Module Error"
             (which is exactly what happened). ARR already appends X-Forwarded-For,
             and the read-only gateway does not depend on the host/proto headers, so
             they are omitted. To re-add them, first allow the variables (elevated):
               appcmd set config -section:system.webServer/rewrite/allowedServerVariables /+"[name='HTTP_X_FORWARDED_HOST']" /commit:apphost
               appcmd set config -section:system.webServer/rewrite/allowedServerVariables /+"[name='HTTP_X_FORWARDED_PROTO']" /commit:apphost -->
        <rule name="Proxy API to Node gateway" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/api/{R:1}" />
        </rule>

        <!-- Root -> dashboard -->
        <rule name="Root to dashboard" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="dashboard.html" />
        </rule>
      </rules>

      <rewriteMaps>
        <rewriteMap name="MapProtocol">
          <add key="on" value="https" />
          <add key="off" value="http" />
        </rewriteMap>
      </rewriteMaps>

      <!-- Strip the upstream Server header from proxied responses. -->
      <outboundRules>
        <rule name="Remove Server header">
          <match serverVariable="RESPONSE_Server" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- =====================================================================
         Headers: caching + security
         ===================================================================== -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
        <!--
          Content-Security-Policy.
          'unsafe-inline' is required because dashboard.html carries an inline
          <script> and inline <style>. TradingView is allowed for the chart and
          ticker widgets; its logo CDN is allowed for symbol images.
          connect-src includes 'self' so the ARR-proxied /api path works, plus
          localhost:3001 for the direct-connection fallback.
        -->
        <add name="Content-Security-Policy"
             value="default-src 'self';
                    script-src 'self' 'unsafe-inline' https://s3.tradingview.com https://www.tradingview-widget.com https://charting-library.tradingview-widget.com;
                    style-src 'self' 'unsafe-inline';
                    img-src 'self' data: https://s3-symbol-logo.tradingview.com https://*.tradingview.com https://*.tradingview-widget.com;
                    frame-src https://s.tradingview.com https://www.tradingview.com https://www.tradingview-widget.com https://charting-library.tradingview-widget.com;
                    connect-src 'self' http://localhost:3001 http://127.0.0.1:3001 https://*.tradingview.com wss://*.tradingview.com https://*.tradingview-widget.com wss://*.tradingview-widget.com;
                    object-src 'none'; base-uri 'self'" />
      </customHeaders>
    </httpProtocol>

    <caching enabled="true" enableKernelCache="true">
      <profiles>
        <!-- The engine changes with releases; revalidate rather than cache hard. -->
        <add extension=".js" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".json" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <!-- Never cache the shell: it wires up the engine. -->
        <add extension=".html" policy="DisableCache" kernelCachePolicy="DisableCache" />
      </profiles>
    </caching>

    <!-- Request limits: this is a read-only dashboard. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="1048576" />
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="tests" />
          <add segment=".git" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".log" allowed="false" />
        </fileExtensions>
        <verbs allowUnlisted="false">
          <add verb="GET" allowed="true" />
          <add verb="HEAD" allowed="true" />
          <add verb="OPTIONS" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>

    <httpErrors errorMode="Custom" existingResponse="PassThrough" />

  </system.webServer>
</configuration>
